{
  "id": "/belajar_pwa_pertama/",
  "name": "RenTrack - Vehicle Monitoring",
  "short_name": "RenTrack",
  "description": "Sistem monitoring kendaraan rental real-time dengan pelacakan GPS, manajemen armada, dan notifikasi.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone"
  ],
  "background_color": "#F3F4F6",
  "theme_color": "#2563EB",
  "orientation": "portrait",
  "lang": "id",
  "dir": "ltr",
  "categories": [
    "productivity",
    "utilities",
    "business"
  ],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://gilangangga04.github.io/belajar_pwa_pertama/manifest.json"
    }
  ],
  "prefer_related_applications": false,
  "handle_links": "preferred",
  "scope_extensions": [
    {
      "origin": "https://gilangangga04.github.io"
    }
  ],
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "application/json": [".json"]
      }
    }
  ],
  "protocol_handlers": [
